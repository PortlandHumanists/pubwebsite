# TinaCMS credentials — copy this file to .env and fill in real values
# Get these from app.tina.io → your project → Settings → Tokens

TINA_PUBLIC_CLIENT_ID=your-client-id-here
TINA_TOKEN=your-token-here
TINA_SEARCH_TOKEN=your-search-token-here

# PayPal — get Client ID from developer.paypal.com → Apps & Credentials
# Use Sandbox client ID for testing, Live client ID for production
PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id-here
