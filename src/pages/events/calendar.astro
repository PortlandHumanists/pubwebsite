---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="Calendar - Humanists of Greater Portland">
  <!-- Hero -->
  <section class="hgp-cta text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Calendar</h1>
      <p class="text-xl text-[var(--hgp-on-primary)] max-w-2xl">
        View all HGP events in calendar form, or add our calendar to your own Google Calendar.
      </p>
    </div>
  </section>

  <!-- Subnav -->
  <div class="bg-white border-b border-neutral-200 sticky top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 py-2">
        <a href="/events" class="px-4 py-2 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-100 transition-colors">Upcoming</a>
        <a href="/events/calendar" class="px-4 py-2 rounded-lg text-sm font-medium bg-[var(--hgp-surface)] text-[var(--hgp-primary)]">Calendar</a>
        <a href="/events/past" class="px-4 py-2 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-100 transition-colors">Past Programs</a>
      </nav>
    </div>
  </div>

  <!-- Calendar Embed -->
  <section class="py-16 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-neutral-900">HGP Google Calendar</h2>
        <a
          href="https://calendar.google.com/calendar/u/1?cid=cG9ydGxhbmRodW1hbmlzdHNAZ21haWwuY29t"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-[var(--hgp-primary)] hover:underline font-medium"
        >
          Open in Google Calendar
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

      <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-neutral-200">
        <iframe
          src="https://calendar.google.com/calendar/embed?src=portlandhumanists%40gmail.com&ctz=America%2FLos_Angeles&showTitle=0&showNav=1&showPrint=0&showCalendars=0&showTz=1"
          style="border: 0"
          width="100%"
          height="680"
          frameborder="0"
          scrolling="no"
          title="Humanists of Greater Portland — Google Calendar"
        ></iframe>
      </div>

      <!-- Subscribe instructions -->
      <div class="mt-8 bg-white rounded-xl p-6 border border-neutral-200">
        <h3 class="font-semibold text-neutral-900 mb-2">Add to your Google Calendar</h3>
        <p class="text-sm text-neutral-600">
          Click "Open in Google Calendar" above, then click <strong>+ Add calendar</strong> to subscribe and see HGP events alongside your personal calendar.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
