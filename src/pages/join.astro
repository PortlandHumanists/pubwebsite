---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { JoinVisualEditor } from '../components/JoinVisualEditor';
import client from '../../tina/__generated__/client';

const tinaResult = await client.queries.joinPage({ relativePath: 'join.json' });
const paypalClientId = import.meta.env.PUBLIC_PAYPAL_CLIENT_ID ?? '';
---

<BaseLayout title="Join Us - Humanists of Greater Portland">
  <!-- Netlify Forms: decoy form for build-time detection -->
  <form name="membershipForm" netlify hidden>
    <input name="membershipType" />
    <input name="membershipAmount" />
    <input name="agreePhilosophy" />
    <input name="lifetimeMember" />
    <input name="firstName" />
    <input name="lastName" />
    <input name="email" />
    <input name="phone" />
    <input name="address" />
    <input name="city" />
    <input name="state" />
    <input name="zip" />
    <input name="paypalOrderId" />
  </form>

  <JoinVisualEditor
    query={tinaResult.query}
    variables={tinaResult.variables}
    data={tinaResult.data}
    client:tina
  />
</BaseLayout>

<script define:vars={{ paypalClientId }}>
  // Load PayPal SDK
  if (paypalClientId) {
    const sdkScript = document.createElement('script');
    sdkScript.src = `https://www.paypal.com/sdk/js?client-id=${paypalClientId}&currency=USD&intent=capture`;
    document.head.appendChild(sdkScript);
  }

  const form = document.getElementById('membershipForm');
  const membershipAmountInput = document.getElementById('membershipAmount');
  const totalAmountDiv = document.getElementById('totalAmount');
  const stage1Content = document.getElementById('stage1Content');
  const stage2Content = document.getElementById('stage2Content');

  function updateTotal() {
    const amount = parseFloat(membershipAmountInput?.value || '0');
    if (totalAmountDiv) {
      totalAmountDiv.innerHTML = `
        <div class="flex justify-between items-center">
          <span class="text-neutral-700 font-medium">Total Amount:</span>
          <span class="text-2xl font-bold text-[var(--hgp-primary)]">$${amount.toFixed(2)}</span>
        </div>
      `;
    }
  }

  // Update placeholder when membership type changes
  form?.querySelectorAll('input[name="membershipType"]').forEach(input => {
    input.addEventListener('change', (e) => {
      const type = e.target.value;
      if (membershipAmountInput) {
        switch(type) {
          case 'individual': membershipAmountInput.placeholder = '50'; break;
          case 'joint':      membershipAmountInput.placeholder = '90'; break;
          case 'newsletter':
            membershipAmountInput.placeholder = '12';
            membershipAmountInput.value = '12';
            updateTotal();
            break;
          case 'limited':    membershipAmountInput.placeholder = '0'; break;
        }
      }
    });
  });

  membershipAmountInput?.addEventListener('input', updateTotal);

  // Stage 1 → Stage 2 transition
  document.getElementById('continueToStage2')?.addEventListener('click', () => {
    // Validate all required fields in stage 1
    const stage1Inputs = stage1Content?.querySelectorAll('input[required], textarea[required]');
    let valid = true;
    stage1Inputs?.forEach(field => {
      if (!field.checkValidity()) {
        field.reportValidity();
        valid = false;
      }
    });
    if (!valid) return;

    // Show stage 2
    if (stage1Content) stage1Content.style.display = 'none';
    if (stage2Content) {
      stage2Content.style.display = 'block';
      stage2Content.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    renderPayPal();
  });

  // Helper: submit form data to Netlify and show thank you
  async function submitAndThankYou(paypalOrderId) {
    const formData = new FormData(form);
    const body = new URLSearchParams({ 'form-name': 'membershipForm', paypalOrderId });
    for (const [key, val] of formData.entries()) body.append(key, val.toString());
    await fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: body.toString(),
    });
    const formSection = document.getElementById('membershipFormSection');
    const thankYouSection = document.getElementById('thankYouSection');
    if (formSection) formSection.style.display = 'none';
    if (thankYouSection) thankYouSection.style.display = 'block';
  }

  // Complete without payment
  document.getElementById('completeWithoutPayment')?.addEventListener('click', () => {
    submitAndThankYou('none');
  });

  // Render PayPal button (called after stage 1 is complete)
  let paypalRendered = false;
  function renderPayPal() {
    if (paypalRendered) return;
    if (typeof window.paypal === 'undefined') {
      setTimeout(renderPayPal, 200);
      return;
    }
    paypalRendered = true;
    window.paypal.Buttons({
      onClick: (_data, actions) => {
        const amount = parseFloat(membershipAmountInput?.value || '0');
        if (amount <= 0) {
          membershipAmountInput?.setCustomValidity('Please enter an amount greater than $0 to pay via PayPal, or click "Complete Membership" to join without a payment.');
          membershipAmountInput?.reportValidity();
          return actions.reject();
        }
        membershipAmountInput?.setCustomValidity('');
        return actions.resolve();
      },
      createOrder: (_data, actions) => {
        const amount = parseFloat(membershipAmountInput?.value || '0');
        return actions.order.create({
          purchase_units: [{
            description: 'HGP Membership',
            amount: { value: amount.toFixed(2) },
          }],
        });
      },
      onApprove: async (data, actions) => {
        await actions.order.capture();
        await submitAndThankYou(data.orderID);
      },
      onError: (err) => {
        console.error('PayPal error', err);
        alert('Payment failed. Please try again or contact us at info@portlandhumanists.org.');
      },
    }).render('#paypal-button-container');
  }
</script>
